{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Azure Cross-Tenant Access Settings Schema",
  "definitions": {
    "access_type": {
      "type": "string",
      "enum": ["allowed", "blocked", "unknownFutureValue"]
    },
    "trust_settings": {
      "type": "object",
      "properties": {
        "mfa_accepted": { "type": "boolean" },
        "compliant_device_accepted": { "type": "boolean" },
        "hybrid_azure_ad_joined_device_accepted": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "b2b_setting": {
      "type": "object",
      "properties": {
        "access_type": { "$ref": "#/definitions/access_type" }
      },
      "additionalProperties": false
    },
    "identity_sync_settings": {
      "type": "object",
      "properties": {
        "user": { "type": "boolean" },
        "group": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "tenant_restrictions_settings": {
      "type": "object",
      "properties": {
        "access_type": { "$ref": "#/definitions/access_type" }
      },
      "additionalProperties": false
    },
    "defaults": {
      "type": "object",
      "properties": {
        "inbound": {
          "type": "object",
          "properties": {
            "b2b_collaboration": { "$ref": "#/definitions/b2b_setting" },
            "b2b_direct_connect": { "$ref": "#/definitions/b2b_setting" },
            "trust": { "$ref": "#/definitions/trust_settings" }
          },
          "additionalProperties": false
        },
        "outbound": {
          "type": "object",
          "properties": {
            "b2b_collaboration": { "$ref": "#/definitions/b2b_setting" },
            "b2b_direct_connect": { "$ref": "#/definitions/b2b_setting" }
          },
          "additionalProperties": false
        },
        "tenant_restrictions": { "$ref": "#/definitions/tenant_restrictions_settings" }
      },
      "required": ["inbound", "outbound", "tenant_restrictions"],
      "additionalProperties": false
    },
    "peer": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "fqdn": { "type": "string" },
        "tenant_id": { "type": "string", "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$" },
        "inbound": {
          "type": "object",
          "properties": {
            "automatic_user_consent": { "type": "boolean" },
            "identity_sync": { "$ref": "#/definitions/identity_sync_settings" },
            "b2b_collaboration": { "$ref": "#/definitions/b2b_setting" },
            "trust": { "$ref": "#/definitions/trust_settings" }
          },
          "additionalProperties": false
        },
        "outbound": {
          "type": "object",
          "properties": {
            "automatic_user_consent": { "type": "boolean" },
            "b2b_collaboration": { "$ref": "#/definitions/b2b_setting" }
          },
          "additionalProperties": false
        },
        "tenant_restrictions": { "$ref": "#/definitions/tenant_restrictions_settings" }
      },
      "required": ["name", "fqdn", "tenant_id"],
      "additionalProperties": false
    },
    "peers": {
      "type": "array",
      "items": { "$ref": "#/definitions/peer" }
    }
  },
  "oneOf": [
    { "$ref": "#/definitions/defaults" },
    { "$ref": "#/definitions/peers" }
  ]
}
